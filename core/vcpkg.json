{
  "name": "solra-core",
  "version-string": "0.1.0",
  "description": "Solra Core SDK - Cross-platform 3D rendering, on-device inference, streaming, and WebRTC engine",
  "homepage": "https://github.com/solra/solra",
  "license": "Apache-2.0",
  "dependencies": [
    {
      "name": "glm",
      "version>=": "1.0.1"
    },
    {
      "name": "gtest",
      "version>=": "1.14.0"
    },
    {
      "name": "benchmark",
      "version>=": "1.8.3"
    },
    {
      "name": "protobuf",
      "version>=": "3.21.0"
    },
    {
      "name": "spdlog",
      "version>=": "1.13.0"
    },
    {
      "name": "nlohmann-json",
      "version>=": "3.11.3"
    },
    {
      "name": "stb"
    },
    {
      "name": "zlib",
      "version>=": "1.3.1"
    },
    {
      "name": "openssl",
      "version>=": "3.3.0"
    }
  ],
  "features": {
    "metal": {
      "description": "Metal rendering backend (iOS/macOS)",
      "supports": "osx & (arm64 | x64)"
    },
    "vulkan": {
      "description": "Vulkan rendering backend (Android/Windows)",
      "supports": "!osx"
    },
    "opengles": {
      "description": "OpenGL ES fallback rendering backend",
      "supports": "android | linux"
    },
    "coreml": {
      "description": "CoreML NPU backend (iOS/macOS)",
      "supports": "osx & (arm64 | x64)"
    },
    "nnapi": {
      "description": "Android NNAPI backend",
      "supports": "android"
    },
    "tests": {
      "description": "Build unit tests and benchmarks",
      "dependencies": [
        "gtest",
        "benchmark"
      ]
    }
  }
}
